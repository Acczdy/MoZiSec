# ========== 核心功能：自动发现工作区 ==========
discover_workspaces() {
    DISCOVERED_WORKSPACES=()
    WORKSPACE_NAMES=()
    WORKSPACE_ALIASES=()
    WORKSPACE_GROUPS=()

    for dir in "$SCRIPT_DIR"/*/; do
        [ ! -d "$dir" ] && continue
        local dirname=$(basename "$dir")

        # 跳过系统目录
        case "$dirname" in
            "."|""|"tmp"|".claude"|"memory"|".git"|"node_modules") continue ;;
        esac

        # 检查工作区标识：CLAUDE.md 存在
        if [ -f "$dir/CLAUDE.md" ]; then
            DISCOVERED_WORKSPACES+=("$dirname")

            # 从 CLAUDE.md 提取名称
            local name=$(grep -m1 "^# " "$dir/CLAUDE.md" 2>/dev/null | sed 's/^# //' | head -c 50)
            WORKSPACE_NAMES["$dirname"]="${name:-$dirname}"

            # 优先从 CLAUDE.md 读取分组配置（支持 HTML 注释格式）
            local group_from_md=$(grep -m1 "<!-- *group:" "$dir/CLAUDE.md" 2>/dev/null | sed 's/.*<!-- *group: *\([^>]*\) *-->/\1/' | tr -d ' ')
            if [ -n "$group_from_md" ]; then
                WORKSPACE_GROUPS["$dirname"]="$group_from_md"
            else
                # 使用默认分组
                WORKSPACE_GROUPS["$dirname"]="${DEFAULT_GROUPS[$dirname]:-专项领域}"
            fi

            # 从 CLAUDE.md 读取别名配置
            local alias_from_md=$(grep -m1 "<!-- *alias:" "$dir/CLAUDE.md" 2>/dev/null | sed 's/.*<!-- *alias: *\([^>]*\) *-->/\1/' | tr -d ' ')
            if [ -n "$alias_from_md" ]; then
                WORKSPACE_ALIASES["$dirname"]="$alias_from_md"
            else
                # 设置默认别名
                local alias=$(echo "$dirname" | tr '[:upper:]' '[:lower:]' | sed 's/-//g' | cut -c1-3)
                WORKSPACE_ALIASES["$dirname"]="$alias"
            fi

            # 设置名言
            if [ -z "${MOZI_QUOTES[$dirname]}" ]; then
                MOZI_QUOTES["$dirname"]="守土有责，防患未然"
            fi
        fi
    done

    # 排序
    IFS=$'\n' DISCOVERED_WORKSPACES=($(sort <<<"${DISCOVERED_WORKSPACES[*]}"))
    unset IFS

    # 构建分组列表（基础分组 + 自动发现的自定义分组）
    MOZI_GROUPS=("${MOZI_GROUPS_BASE[@]}")
    for dir in "${DISCOVERED_WORKSPACES[@]}"; do
        local grp="${WORKSPACE_GROUPS[$dir]}"
        local found=0
        # 检查是否已存在
        for g in "${MOZI_GROUPS[@]}"; do
            [ "$g" == "$grp" ] && { found=1; break; }
        done
        # 添加新分组
        [ $found -eq 0 ] && MOZI_GROUPS+=("$grp")
    done
}

