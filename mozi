# ========== 交互菜单 ==========
role_interact() {
    local dir="$1"
    while true; do
        echo ""
        echo -e "${WHITE}${BOLD}  ┌────────────────────────────────────────────────────────────┐${RESET}"
        echo -e "${WHITE}${BOLD}  │${RESET}  ${GREEN}[1]${RESET} 启动 claude    ${GREEN}[2]${RESET} claude --resume"
        echo -e "${WHITE}${BOLD}  │${RESET}  ${GREEN}[3]${RESET} 手动命令      ${GREEN}[h]${RESET} 技能帮助      ${GREEN}[b]${RESET} 返回菜单    ${GREEN}[q]${RESET} 退出"
        echo -e "${WHITE}${BOLD}  └────────────────────────────────────────────────────────────┘${RESET}"
        echo -ne "${CYAN}  操作 > ${RESET}"
        read -r choice
        case "$choice" in
            1) echo -e "${CYAN}  启动 claude...${RESET}"; cd "$SCRIPT_DIR/$dir" && claude; break ;;
            2) echo -e "${CYAN}  启动 claude --resume...${RESET}"; cd "$SCRIPT_DIR/$dir" && claude --resume; break ;;
            3) echo -e "${CYAN}  手动模式${RESET}"; cd "$SCRIPT_DIR/$dir"; read -p "$ " cmd; [ -n "$cmd" ] && eval "$cmd" ;;
            h|H)
                echo -e "${WHITE}  可用 Skills:${RESET}"
                echo -e "${GRAY}  ─────────────────────────────────────────────────────────────${RESET}"
                list_skills "$dir" | while read skill; do
                    echo -e "    ${GREEN}/$skill${RESET}"
                done
                ;;
            b|B) break ;;
            q|Q) echo -e "${GRAY}  退出 MoZiSec${RESET}"; exit 0 ;;
            *) echo -e "${YELLOW}  无效命令${RESET}" ;;
        esac
    done
}

