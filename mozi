# ========== 历史记录功能 ==========
record_visit() {
    local dir="$1"
    local timestamp=$(date +%s)

    mkdir -p "$(dirname "$MOZI_HISTORY_FILE")"

    local history=()
    if [ -f "$MOZI_HISTORY_FILE" ]; then
        while IFS= read -r line; do
            [ -n "$line" ] && history+=("$line")
        done < "$MOZI_HISTORY_FILE"
    fi

    local new_history=()
    for item in "${history[@]}"; do
        local old_dir=$(echo "$item" | cut -d'|' -f2)
        [ "$old_dir" != "$dir" ] && new_history+=("$item")
    done

    new_history=("$timestamp|$dir" "${new_history[@]}")
    [ ${#new_history[@]} -gt 5 ] && new_history=("${new_history[@]:0:5}")

    printf '%s\n' "${new_history[@]}" > "$MOZI_HISTORY_FILE"
}

get_last_visit_time() {
    local dir="$1"
    if [ -f "$MOZI_HISTORY_FILE" ]; then
        local record=$(grep "|$dir$" "$MOZI_HISTORY_FILE" | head -1)
        if [ -n "$record" ]; then
            local ts=$(echo "$record" | cut -d'|' -f1)
            local now=$(date +%s)
            local diff=$((now - ts))

            if [ $diff -lt 60 ]; then echo "刚刚"
            elif [ $diff -lt 3600 ]; then echo "$((diff / 60)) 分钟前"
            elif [ $diff -lt 86400 ]; then echo "$((diff / 3600)) 小时前"
            else echo "$((diff / 86400)) 天前"
            fi
            return
        fi
    fi
    echo ""
}

