    mkdir -p "$SCRIPT_DIR/$ws_name/.claude/skills"
    mkdir -p "$SCRIPT_DIR/$ws_name/tmp"

    # 创建 CLAUDE.md
    cat > "$SCRIPT_DIR/$ws_name/CLAUDE.md" << EOF
# $ws_title

## 启动方式

\`\`\`bash
cd $SCRIPT_DIR/$ws_name
claude
\`\`\`

## 角色定义

在此定义该工作区的角色定位和专业领域。

## 技能目录

技能位于 \`.claude/skills/\` 目录。

## 文件创建规范

临时文件必须写入 \`tmp/\` 目录。
EOF

    echo ""
    echo -e "${GREEN}  ✓ 工作区创建成功：$ws_name${RESET}"
    echo -e "${GRAY}  位置：$SCRIPT_DIR/$ws_name${RESET}"
    echo ""
    echo -e "${GRAY}  按回车返回...${RESET}"
    read

    discover_workspaces
}

# ========== 解析用户输入 ==========
parse_role_input() {
    local input="$1"
    local lower_input="${1,,}"

    if [[ "$lower_input" =~ ^[0-9]+$ ]]; then
        for item in "${COMMON_WORKSPACES[@]}"; do
            IFS='|' read -r idx dir alias name <<< "$item"
            [ "$idx" == "$lower_input" ] && { echo "$dir"; return; }
        done
    fi

    for dir in "${DISCOVERED_WORKSPACES[@]}"; do
        local lower_dir="${dir,,}"
        local lower_alias="${WORKSPACE_ALIASES[$dir],,}"
        [ "$lower_input" == "$lower_dir" ] || [ "$lower_input" == "$lower_alias" ] && { echo "$dir"; return; }
    done

    for d in "$SCRIPT_DIR"/*/; do
        local lower_d="${d,,}"
        if [[ "$lower_d" == *"/${lower_input}/" ]]; then
            echo "${d%/}"
            return
        fi
    done

    [ -d "$SCRIPT_DIR/$input" ] && { echo "$input"; return; }
    return 1
}

# ========== 主入口 ==========
mozi_cd() {
    local input="$1"
    [ -z "$input" ] && { mozi_interactive; return; }
    local dir=$(parse_role_input "$input")
    if [ -n "$dir" ] && [ -d "$SCRIPT_DIR/$dir" ]; then
        enter_workspace "$dir"
    else
        echo -e "${YELLOW}未知的工作区：$input${RESET}"
    fi
}

mozi_init() {
    cat << 'INIT_EOF'
export MOZI_PROJECT="MoZiSec"
export MOZI_VERSION="v1.0"
export MOZI_WORKSPACE_ROOT="$SCRIPT_DIR"

mozi() { [ -z "$1" ] && mozi_cd || mozi_cd "$1"; }
alias mozi-help='mozi h'
alias mozi-config='mozi c'
alias mozi-create='mozi create'
INIT_EOF
}

mozi_interactive() {
    discover_workspaces

    if check_fzf; then
        show_main_menu_fzf
    else
        show_banner
        echo -e "${YELLOW}  未安装 fzf"
        if [[ "$IS_WINDOWS" == true ]]; then
            echo -e "${GRAY}  Windows: choco install fzf 或 winget install fzf${RESET}"
        else
            echo -e "${GRAY}  Linux: apt install fzf 或 brew install fzf${RESET}"
        fi
        echo -e "${GRAY}  按回车返回...${RESET}"
        read
    fi
}

# ========== 脚本入口 ==========
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    discover_workspaces

    if [ "$1" = "init" ]; then
        mozi_init
    elif [ "$1" = "create" ] || [ "$1" = "new" ]; then
        create_workspace_interactive
    elif [ -z "$1" ]; then
        mozi_interactive
    else
        mozi_cd "$1"
    fi
fi
