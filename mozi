}

# ========== 统计技能数量 ==========
count_skills() {
    local dir="$1"
    local skills_dir="$SCRIPT_DIR/$dir/.claude/skills"
    if [ -d "$skills_dir" ]; then
        find "$skills_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l
    else
        echo "0"
    fi
}

list_skills() {
    local dir="$1"
    local skills_dir="$SCRIPT_DIR/$dir/.claude/skills"
    if [ -d "$skills_dir" ]; then
        find "$skills_dir" -maxdepth 1 -mindepth 1 -type d -exec basename {} \; 2>/dev/null | sort
    fi
}

