create_workspace_interactive() {
    show_banner
    echo -e "${WHITE}${BOLD}  ┌────────────────────────────────────────────────────────────┐${RESET}"
    echo -e "${WHITE}${BOLD}  │                  创建工作区                                │${RESET}"
    echo -e "${WHITE}${BOLD}  └────────────────────────────────────────────────────────────┘${RESET}"
    echo ""

    echo -ne "  工作区名称 (英文，带连字符): "
    read -r ws_name

    if [ -z "$ws_name" ]; then
        echo -e "${YELLOW}  名称不能为空${RESET}"
        return
    fi

    if [ -d "$SCRIPT_DIR/$ws_name" ]; then
        echo -e "${YELLOW}  目录已存在：$SCRIPT_DIR/$ws_name${RESET}"
        echo -e "${GRAY}  按回车返回...${RESET}"
        read
        return
    fi

    echo -ne "  中文名称 (如：JS 安全分析): "
    read -r ws_title

    echo -ne "  别名 (如：jsc): "
    read -r ws_alias

    echo -ne "  分组： "
    read -r ws_group
    [ -z "$ws_group" ] && ws_group="专项领域"

    echo -ne "  名言 (可选): "
    read -r ws_quote
    [ -z "$ws_quote" ] && ws_quote="守土有责，防患未然"

